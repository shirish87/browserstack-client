{
  "name": "@dot-slash/browserstack-test-reporting",
  "publishConfig": {
    "access": "public"
  },
  "version": "4.1.0-alpha.1",
  "type": "module",
  "description": "BrowserStack Test Reporting & Analytics API client",
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit || true",
    "test": "vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "@dot-slash/browserstack-core": "workspace:*",
    "@dot-slash/browserstack-openapi": "workspace:*",
    "@dot-slash/browserstack-openapi-transforms": "workspace:*",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
