{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "rewriteRelativeImportExtensions": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"]
