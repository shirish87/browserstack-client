{
  "name": "@browserstack-client/openapi-transforms",
  "version": "0.1.0-dev",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.ts",
      "import": "./dist/codegen/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:mem": "node --expose-gc ./node_modules/vitest/vitest.mjs run src/__tests__/streaming/memory.test.ts"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0",
    "@streamparser/json": "^0.0.21"
  },
  "peerDependencies": {
    "openapi-fetch": "^0.9.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "fast-check": "^3.23.0",
    "openapi-fetch": "0.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^1.6.1",
    "yaml": "^2.6.0"
  }
}
