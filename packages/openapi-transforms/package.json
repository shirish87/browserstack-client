{
  "name": "@browserstack-client/openapi-transforms",
  "version": "0.1.0-dev",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./codegen": {
      "types": "./dist/codegen/typescript/index.d.ts",
      "import": "./dist/codegen/typescript/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:mem": "node --expose-gc ./node_modules/vitest/vitest.mjs run src/__tests__/streaming/memory.test.ts"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@streamparser/json": "^0.0.22"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "fast-check": "^4.7.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "yaml": "^2.8.3"
  }
}
