{
  "name": "@browserstack-client/core",
  "version": "6.0.0",
  "type": "module",
  "description": "Shared runtime utilities: APIClient base, auth, error handling, HTTP adapters",
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit || true"
  },
  "dependencies": {
    "@browserstack-client/openapi-transforms": "workspace:*"
  },
  "devDependencies": {
    "@browserstack-client/openapi": "workspace:*",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
