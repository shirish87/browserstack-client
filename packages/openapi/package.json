{
  "name": "@dot-slash/browserstack-openapi",
  "private": true,
  "version": "6.1.0",
  "type": "module",
  "description": "OpenAPI specs and generated TypeScript types for BrowserStack APIs",
  "files": [
    "generated/**/*.ts",
    "generated/**/*.json",
    "specs/**/*.yml"
  ],
  "exports": {
    ".": "./generated/index.ts",
    "./automate": "./generated/automate.ts",
    "./automate/client": "./generated/automate.client.ts",
    "./app-automate": "./generated/app-automate.ts",
    "./app-automate/client": "./generated/app-automate.client.ts",
    "./screenshots": "./generated/screenshots.ts",
    "./screenshots/client": "./generated/screenshots.client.ts",
    "./local-testing": "./generated/local-testing.ts",
    "./local-testing/client": "./generated/local-testing.client.ts",
    "./local-testing-binary": "./generated/local-testing-binary.ts",
    "./test-management": "./generated/test-management.ts",
    "./test-management/client": "./generated/test-management.client.ts",
    "./accessibility": "./generated/accessibility.ts",
    "./accessibility/client": "./generated/accessibility.client.ts",
    "./test-reporting": "./generated/test-reporting.ts",
    "./test-reporting/client": "./generated/test-reporting.client.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "true"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3",
    "yaml": "^2.8.3"
  },
  "dependencies": {
    "@dot-slash/browserstack-openapi-transforms": "workspace:*"
  }
}
