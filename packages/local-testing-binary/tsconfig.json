{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "@dot-slash/browserstack-local-testing": ["./src/index.ts"],
      "@dot-slash/browserstack-core": ["../core/src/index.ts"],
      "@dot-slash/browserstack-core/__tests__/*": ["../core/src/__tests__/*.ts"],
      "@dot-slash/browserstack-local-testing-api": ["../local-testing/src/index.ts"],
      "@dot-slash/browserstack-openapi/local-testing": ["../openapi/generated/local-testing.ts"]
    }
  },
  "include": ["src"]
}
