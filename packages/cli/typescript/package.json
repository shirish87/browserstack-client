{
  "name": "@dot-slash/browserstack-cli",
  "publishConfig": {
    "access": "public"
  },
  "version": "6.1.0",
  "type": "module",
  "description": "Command-line interface for BrowserStack Local Testing and App Automate",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "browserstack-cli": "./dist/browserstack-client.js",
    "browserstack-client": "./dist/browserstack-client.js",
    "browserstack-test-reporting": "./dist/browserstack-test-reporting.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/browserstack-client.d.ts",
      "import": "./dist/browserstack-client.js",
      "require": "./dist/browserstack-client.cjs"
    },
    "./local": {
      "types": "./dist/browserstack-local.d.ts",
      "import": "./dist/browserstack-local.js",
      "require": "./dist/browserstack-local.cjs"
    },
    "./app-automate": {
      "types": "./dist/browserstack-app-automate.d.ts",
      "import": "./dist/browserstack-app-automate.js",
      "require": "./dist/browserstack-app-automate.cjs"
    },
    "./automate": {
      "types": "./dist/browserstack-automate.d.ts",
      "import": "./dist/browserstack-automate.js",
      "require": "./dist/browserstack-automate.cjs"
    },
    "./local-testing": {
      "types": "./dist/browserstack-local-testing.d.ts",
      "import": "./dist/browserstack-local-testing.js",
      "require": "./dist/browserstack-local-testing.cjs"
    },
    "./test-management": {
      "types": "./dist/browserstack-test-management.d.ts",
      "import": "./dist/browserstack-test-management.js",
      "require": "./dist/browserstack-test-management.cjs"
    },
    "./accessibility": {
      "types": "./dist/browserstack-accessibility.d.ts",
      "import": "./dist/browserstack-accessibility.js",
      "require": "./dist/browserstack-accessibility.cjs"
    },
    "./test-reporting": {
      "types": "./dist/browserstack-test-reporting.d.ts",
      "import": "./dist/browserstack-test-reporting.js",
      "require": "./dist/browserstack-test-reporting.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:binary-bundle": "tsup --config tsup.binary.config.ts",
    "build:binary": "pnpm build:binary-bundle && pkg dist-binary/browserstack-client.cjs --targets node18-linux-x64,node18-linux-arm64,node18-macos-x64,node18-macos-arm64,node18-win-x64 --output dist-binary/browserstack-client-ts --compress GZip --fallback-to-source && node -e \"const fs=require('fs'); const renames=[['linux-x64','linux-amd64'],['macos-x64','darwin-amd64'],['macos-arm64','darwin-arm64'],['win-x64.exe','windows-amd64.exe']]; renames.forEach(([oldS,newS])=>{ const p='./dist-binary/browserstack-client-ts-'+oldS; if(fs.existsSync(p)) fs.renameSync(p, './dist-binary/browserstack-client-ts-'+newS); })\"",
    "typecheck": "tsc --noEmit || true"
  },
  "pkg": {
    "assets": [],
    "scripts": []
  },
  "dependencies": {
    "signal-exit": "^4.1.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@dot-slash/browserstack-accessibility": "workspace:*",
    "@dot-slash/browserstack-app-automate": "workspace:*",
    "@dot-slash/browserstack-automate": "workspace:*",
    "@dot-slash/browserstack-core": "workspace:*",
    "@dot-slash/browserstack-local-testing": "workspace:*",
    "@dot-slash/browserstack-local-testing-api": "workspace:*",
    "@dot-slash/browserstack-openapi-transforms": "workspace:*",
    "@dot-slash/browserstack-screenshots": "workspace:*",
    "@dot-slash/browserstack-test-management": "workspace:*",
    "@dot-slash/browserstack-test-reporting": "workspace:*",
    "@types/node": "20.0.0",
    "@yao-pkg/pkg": "^6.18.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
