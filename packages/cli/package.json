{
  "name": "@browserstack-client/cli",
  "version": "6.0.0",
  "type": "module",
  "description": "Command-line interface for BrowserStack Local Testing and App Automate",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "browserstack-client": "./dist/browserstack-client.js",
    "browserstack-test-reporting": "./dist/browserstack-test-reporting.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/browserstack-client.d.ts",
      "import": "./dist/browserstack-client.js"
    },
    "./local": {
      "types": "./dist/browserstack-local.d.ts",
      "import": "./dist/browserstack-local.js"
    },
    "./app-automate": {
      "types": "./dist/browserstack-app-automate.d.ts",
      "import": "./dist/browserstack-app-automate.js"
    },
    "./automate": {
      "types": "./dist/browserstack-automate.d.ts",
      "import": "./dist/browserstack-automate.js"
    },
    "./local-testing": {
      "types": "./dist/browserstack-local-testing.d.ts",
      "import": "./dist/browserstack-local-testing.js"
    },
    "./test-management": {
      "types": "./dist/browserstack-test-management.d.ts",
      "import": "./dist/browserstack-test-management.js"
    },
    "./accessibility": {
      "types": "./dist/browserstack-accessibility.d.ts",
      "import": "./dist/browserstack-accessibility.js"
    },
    "./test-reporting": {
      "types": "./dist/browserstack-test-reporting.d.ts",
      "import": "./dist/browserstack-test-reporting.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:binary-bundle": "tsup --config tsup.binary.config.ts",
    "build:binary": "pnpm build:binary-bundle && pkg dist-binary/browserstack-client.cjs --targets node18-linux-x64,node18-macos-arm64,node18-win-x64 --output dist-binary/browserstack-client --compress GZip --fallback-to-source",
    "typecheck": "tsc --noEmit || true"
  },
  "pkg": {
    "assets": [],
    "scripts": []
  },
  "dependencies": {
    "@browserstack-client/accessibility": "workspace:*",
    "@browserstack-client/app-automate": "workspace:*",
    "@browserstack-client/automate": "workspace:*",
    "@browserstack-client/core": "workspace:*",
    "@browserstack-client/local-testing": "workspace:*",
    "@browserstack-client/local-testing-binary": "workspace:*",
    "@browserstack-client/test-reporting": "workspace:*",
    "@browserstack-client/openapi-transforms": "workspace:*",
    "@browserstack-client/test-management": "workspace:*",
    "signal-exit": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@yao-pkg/pkg": "^6.18.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
