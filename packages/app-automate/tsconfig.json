{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "@dot-slash/browserstack-app-automate": ["./src/index.ts"],
      "@dot-slash/browserstack-core": ["../core/src/index.ts"],
      "@dot-slash/browserstack-openapi": ["../openapi/generated/index.ts"],
      "@dot-slash/browserstack-openapi/*": ["../openapi/generated/*.ts"],
      "@dot-slash/browserstack-openapi-transforms": ["../openapi-transforms/src/index.ts"]
    }
  },
  "include": ["src"]
}
