{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "@browserstack-client/app-automate": ["./src/index.ts"],
      "@browserstack-client/core": ["../core/src/index.ts"],
      "@browserstack-client/openapi": ["../openapi/generated/index.ts"],
      "@browserstack-client/openapi/*": ["../openapi/generated/*.ts"],
      "@browserstack-client/openapi-transforms": ["../openapi-transforms/src/index.ts"]
    }
  },
  "include": ["src"]
}
