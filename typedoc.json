{
  "$schema": "https://typedoc.org/schema.json",
  "out": "./docs/api",
  "docsRoot": "./docs",
  "entryPoints": [
    "./packages/automate",
    "./packages/app-automate",
    "./packages/screenshots",
    "./packages/local-testing",
    "./packages/local-testing-binary",
    "./packages/accessibility",
    "./packages/test-management",
    "./packages/test-reporting",
    "./packages/website-scanner",
    "./packages/core"
  ],
  "entryPointStrategy": "packages",
  "exclude": ["**/__tests__/**", "**/test/**", "**/pkginfo.ts"],
  "excludeInternal": true,
  "excludeNotDocumented": false,
  "sort": ["source-order"],
  "tsconfig": "./tsconfig.docs.json",
  "hideGenerator": true,
  "parametersFormat": "table",
  "propertiesFormat": "table",
  "typeDeclarationFormat": "table",
  "indexFormat": "table",
  "tableColumnSettings": {
    "hideModifiers": true
  },
  "blockTags": ["@param", "@returns", "@throws", "@example", "@see", "@deprecated", "@since", "@module", "@internal", "@packageDocumentation", "@default", "@description"],
  "modifierTags": ["@description"],
  "plugin": ["typedoc-plugin-markdown", "typedoc-vitepress-theme"]
}
