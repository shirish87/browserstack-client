{
  "name": "browserstack-client-monorepo",
  "private": true,
  "type": "module",
  "version": "6.0.0",
  "description": "BrowserStack client SDK monorepo",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' run build",
    "build:types": "pnpm --filter @browserstack-client/openapi run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint packages --ext .ts",
    "check": "tsc --build packages/*/tsconfig.json packages/cli/typescript/tsconfig.json",
    "clean": "pnpm -r exec rimraf dist && rimraf node_modules"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "openapi-fetch": "0.17.0",
    "openapi-typescript": "^7.13.0",
    "openapi-typescript-helpers": "^0.1.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/shirish87/browserstack-client.git"
  },
  "homepage": "https://shirish87.github.io/browserstack-client/",
  "bugs": {
    "url": "https://github.com/shirish87/browserstack-client/issues"
  }
}
