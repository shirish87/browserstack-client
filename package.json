{
  "name": "browserstack-client",
  "private": true,
  "type": "module",
  "version": "6.1.0",
  "description": "BrowserStack client SDK monorepo",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm build:types && pnpm build:go && pnpm build:ts && pnpm build:cli:ts",
    "build:ts": "pnpm -r --filter='@dot-slash/browserstack-*' run build",
    "build:transforms": "pnpm --filter @dot-slash/browserstack-openapi-transforms run build",
    "build:types": "pnpm build:transforms && pnpm --filter @dot-slash/browserstack-openapi run build",
    "build:go": "cd packages/cli/golang && make build",
    "build:cli:go": "pnpm build:go",
    "build:cli:ts": "pnpm --filter @dot-slash/browserstack-cli run build:binary 2>&1 | grep -v 'Warning' | grep -v 'Due to the' | grep -v 'executable is' | grep -v 'Otherwise,' | grep -v 'An ad-hoc' | grep -v 'To do that,' | grep -v 'and run' | grep -v 'install' || true",
    "build:cli": "pnpm build:cli:go && pnpm build:cli:ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint packages --ext .ts",
    "check": "tsc --build --noEmit packages/*/tsconfig.json packages/cli/typescript/tsconfig.json",
    "clean": "pnpm -r exec rimraf dist dist-binary",
    "clean:deps": "pnpm clean && rimraf node_modules",
    "docs:build": "typedoc && vitepress build docs"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@types/node": "20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "mermaid": "^11.15.0",
    "openapi-fetch": "0.17.0",
    "openapi-typescript": "^7.13.0",
    "openapi-typescript-helpers": "^0.1.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.1.4",
    "zod": "^4.4.1"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "openapi-typescript>typescript": "6"
      }
    },
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "vite@<=6.4.1": ">=6.4.2",
      "uuid@<14.0.0": ">=14.0.0",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6"
    }
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/shirish87/browserstack-client.git"
  },
  "homepage": "https://shirish87.github.io/browserstack-client/",
  "bugs": {
    "url": "https://github.com/shirish87/browserstack-client/issues"
  }
}